# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── MySQL (use Railway free tier: railway.app) ────────────────────────────────
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=railway

# ── JWT (use a long random string — min 32 chars) ─────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
CORS_ORIGINS=https://your-app.vercel.app

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_or_sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Gmail SMTP (use an App Password — NOT your real password) ─────────────────
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Domains ───────────────────────────────────────────────────────────────────
# Frontend domain (no protocol, no trailing slash) — used in email links
ROOT_DOMAIN=your-app.vercel.app
# Full backend URL — used to build image upload URLs returned to the frontend
BACKEND_URL=https://your-backend.onrender.com

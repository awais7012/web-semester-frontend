{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Multi-tenant ecommerce REST API — Express.js + MySQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "mysql -u root -p < ../schema.sql",
    "db:seed": "ts-node-dev --transpile-only src/seed.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^8.0.7",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.13.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}

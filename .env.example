# Payload CMS / Database
DATABASE_URI=mongodb://localhost:27017/payload-cms
PAYLOAD_SECRET=testing-secret-key

# App URL — path-based routing (default, no hosts file needed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
NEXT_PUBLIC_ENABLE_SUBDOMAIN_ROUTING="false"

# ─── LOCAL SUBDOMAIN TESTING ──────────────────────────────────────────────────
# To test subdomain routing locally (e.g. awais12354.funroad.local:3000),
# replace the three vars above with these and restart the dev server:
#
#   NEXT_PUBLIC_APP_URL="http://funroad.local:3000"
#   NEXT_PUBLIC_ROOT_DOMAIN="funroad.local:3000"
#   NEXT_PUBLIC_ENABLE_SUBDOMAIN_ROUTING="true"
#
# Then add these lines to /etc/hosts (Mac/Linux) or
# C:\Windows\System32\drivers\etc\hosts (Windows):
#
#   127.0.0.1  funroad.local
#   127.0.0.1  awais12354.funroad.local
#   127.0.0.1  test.funroad.local
#   (add one line per tenant slug you want to test)
#
# Visit http://awais12354.funroad.local:3000 in your browser.
# ──────────────────────────────────────────────────────────────────────────────

# Stripe (https://dashboard.stripe.com/apikeys)
